# Optional. Backend API URL. If unset, the frontend falls back to the host it
# was served from on port 8000 (e.g. http://<page-host>:8000), so it works when
# opened from another device on the network. Set this only to point at a
# different host/port.
# VITE_BACKEND_IP=http://localhost:8000

# Set to true when running on real hardware to hide the simulated pressure sensor button in the Guard screen
# VITE_HIDE_SIMULATE_PRESSURE=true
